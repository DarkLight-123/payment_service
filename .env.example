APP_NAME=payment-processing-service
APP_ENV=dev
API_V1_PREFIX=/api/v1
API_KEY=dev-api-key

POSTGRES_DB=payments_db
POSTGRES_USER=payments_user
POSTGRES_PASSWORD=payments_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

DATABASE_URL=postgresql+asyncpg://payments_user:payments_pass@postgres:5432/payments_db
SYNC_DATABASE_URL=postgresql+psycopg://payments_user:payments_pass@postgres:5432/payments_db

OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_BATCH_SIZE=100
PAYMENTS_EXCHANGE=payments
PAYMENTS_ROUTING_KEY=payments.new
PAYMENTS_QUEUE=payments.new
PAYMENTS_DLQ=payments.dlq
WEBHOOK_TIMEOUT_SECONDS=10
PAYMENT_PROCESSING_MIN_DELAY_SECONDS=2
PAYMENT_PROCESSING_MAX_DELAY_SECONDS=5
PAYMENT_SUCCESS_RATE=0.9
MAX_PROCESSING_ATTEMPTS=3
